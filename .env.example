# Environment for the whole stack. Copy to `.env` and edit, then `docker compose up --build`.
# `.env` is gitignored; only this example is committed.

# --- App ---
YII_ENV=prod                 # prod | dev | test
YII_DEBUG=false              # true enables the debug toolbar (dev only)
# An https:// URL marks the auth cookies (session, CSRF, remember-me) Secure.
APP_URL=http://127.0.0.1:8100
# Signs cookies; keep secret and stable. Generate a fresh random string per deployment.
# Required in production — the app refuses to boot in prod without it (no shared key in git).
COOKIE_VALIDATION_KEY=change-me-to-a-random-32+char-string

# --- Admin (login-gated area) ---
# The only credentials the app knows; nothing is hard-coded in PHP.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# Optional remember-me key. Leave empty to derive one per-deployment from the secrets above.
ADMIN_AUTH_KEY=

# --- Database (app connection) ---
DB_HOST=db
DB_PORT=5432
DB_DATABASE=sitepro
DB_USERNAME=sitepro
DB_PASSWORD=secret

# --- PostgreSQL container init (must match the DB_* values above) ---
POSTGRES_DB=sitepro
POSTGRES_USER=sitepro
POSTGRES_PASSWORD=secret
